# ============================================================
# Knowbase — Environment Variables
# Copy to .env and fill in real values. NEVER commit .env.
# ============================================================

# ── App ──────────────────────────────────────────────────────
APP_NAME=Knowbase
ENVIRONMENT=development        # development | staging | production
DEBUG=true
SECRET_KEY=change-me-generate-with-openssl-rand-hex-32

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/knowbase
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Auth ─────────────────────────────────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256

# ── CORS (comma-separated) ───────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000

# ── AI APIs ──────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# ── Storage (S3-compatible / MinIO for local dev) ────────────
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET_NAME=knowbase
S3_REGION=us-east-1

# ── Frontend ─────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-generate-with-openssl-rand-hex-32

# ── OAuth (optional) ─────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Observability ────────────────────────────────────────────
SENTRY_DSN=
