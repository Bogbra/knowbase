# ============================================================
# Knowbase — Production Environment Variables
# Copy to .env.production and fill in ALL values.
# NEVER commit .env.production to version control.
# ============================================================

# ── App ──────────────────────────────────────────────────────
APP_NAME=Knowbase
ENVIRONMENT=production
DEBUG=false
# Generate: openssl rand -hex 32
SECRET_KEY=CHANGE_ME_openssl_rand_hex_32

# ── Database ─────────────────────────────────────────────────
# POSTGRES_PASSWORD is used by both the postgres service and DATABASE_URL
POSTGRES_PASSWORD=CHANGE_ME_strong_password
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ── Redis ────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_strong_password

# ── Auth ─────────────────────────────────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256

# ── CORS — set to your public domain ────────────────────────
ALLOWED_ORIGINS=["https://yourdomain.com"]

# ── AI APIs ──────────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENAI_API_BASE=
OPENAI_AGENT_MODEL=gpt-4o-mini
TAVILY_API_KEY=

# ── Storage (use real S3 or a managed MinIO in prod) ─────────
S3_ENDPOINT_URL=https://s3.amazonaws.com    # or your MinIO URL
S3_ACCESS_KEY_ID=CHANGE_ME
S3_SECRET_ACCESS_KEY=CHANGE_ME
S3_BUCKET_NAME=knowbase
S3_REGION=eu-central-1

# ── Frontend ─────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://yourdomain.com
NEXTAUTH_URL=https://yourdomain.com
# Generate: openssl rand -hex 32
NEXTAUTH_SECRET=CHANGE_ME_openssl_rand_hex_32

# ── OAuth (optional) ─────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Observability ────────────────────────────────────────────
SENTRY_DSN=
