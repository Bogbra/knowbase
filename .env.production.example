# ============================================================
# Knowbase — Production Environment Variables
# Copy to .env.production and fill in ALL values.
# NEVER commit .env.production to version control.
# ============================================================

# ── App ──────────────────────────────────────────────────────
APP_NAME=Knowbase
ENVIRONMENT=production
DEBUG=false
# Generate: openssl rand -hex 32
SECRET_KEY=CHANGE_ME_openssl_rand_hex_32

# ── Database ─────────────────────────────────────────────────
# Railway provides DATABASE_URL automatically as postgresql://...
# The app auto-converts it to postgresql+asyncpg:// — just paste it as-is.
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/railway
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ── Redis ────────────────────────────────────────────────────
# Railway provides REDIS_URL automatically — paste it as-is.
REDIS_URL=redis://default:password@host:6379

# ── Auth ─────────────────────────────────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256

# ── NextAuth (frontend) ──────────────────────────────────────
# Generate: openssl rand -hex 32
AUTH_SECRET=CHANGE_ME_openssl_rand_hex_32
NEXTAUTH_URL=https://yourdomain.vercel.app
# Internal URL for server-side calls inside Railway (if frontend is also on Railway):
# INTERNAL_API_URL=http://api.railway.internal:8000

# ── CORS — set to your Vercel frontend domain ────────────────
ALLOWED_ORIGINS=["https://yourdomain.vercel.app"]
# Railway/Fly sit in front as a trusted proxy — enables X-Real-IP / X-Forwarded-For
# for per-client rate limiting. Do NOT set in dev (direct port access = spoofable).
TRUST_PROXY_HEADERS=true

# ── AI APIs ──────────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENAI_API_BASE=
OPENAI_AGENT_MODEL=gpt-4o-mini
TAVILY_API_KEY=

# ── Storage (Cloudflare R2 or AWS S3) ────────────────────────
# R2 endpoint format: https://<account-id>.r2.cloudflarestorage.com
S3_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com
S3_ACCESS_KEY_ID=CHANGE_ME
S3_SECRET_ACCESS_KEY=CHANGE_ME
S3_BUCKET_NAME=knowbase
S3_REGION=auto

# ── Frontend (set these in the Vercel dashboard) ─────────────
NEXT_PUBLIC_API_URL=https://your-backend.railway.app

# ── OAuth (optional) ─────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Observability ────────────────────────────────────────────
SENTRY_DSN=
